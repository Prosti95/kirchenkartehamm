{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kirchenkarte - Gottesdienstorte",
  "type": "object",
  "required": ["kirchenkreis", "gottesdienstorte"],
  "properties": {
    "kirchenkreis": { "type": "string" },
    "status_check_date": { "type": "string" },
    "gottesdienstorte": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "address", "coordinates"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "stadtteil": { "type": "string" },
          "address": {
            "type": "object",
            "required": ["street", "zipCode", "city"],
            "properties": {
              "street": { "type": "string", "minLength": 1 },
              "zipCode": { "type": "string", "pattern": "^[0-9]{5}$" },
              "city": { "type": "string", "minLength": 1 }
            }
          },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number", "minimum": 51.4, "maximum": 52.0 },
              "lng": { "type": "number", "minimum": 7.3, "maximum": 8.2 }
            }
          },
          "besonderheiten": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "type": "string" },
                    "emoji": { "type": "string" }
                  }
                }
              ]
            }
          },
          "website": { "type": "string" },
          "buchungsLink": { "type": "string" },
          "photoName": { "type": "string" }
        }
      }
    }
  }
}
